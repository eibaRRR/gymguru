# Copy to `.env` and fill in. `.env` is gitignored.
# docker-compose automatically loads `.env` from the project root.

# Optional — enables LLM coach summaries. Without it a local template is used.
# OPENAI_API_KEY=sk-...

# Optional — point at the heavy pose model for higher accuracy (more CPU).
# GYMGURU_POSE_MODEL=/app/models/pose_landmarker_heavy.task

# Optional — where per-athlete history JSON files are stored.
# GYMGURU_HISTORY_DIR=/data
